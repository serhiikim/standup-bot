# ===========================================
# Slack Standup Bot Configuration
# ===========================================

# Slack Configuration (Required)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Database Configuration
# By default, the app uses SQLite (stored in standup-bot.db in the project root).
# To use MongoDB instead, configure the MONGODB_URI below:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/slack-standup-bot?retryWrites=true&w=majority
# MONGODB_URI=mongodb://mongodb:27017/slack-standup-bot
# SQLITE_DB_PATH=./standup-bot.db

# Basic Auth for Mongo Express (only relevant if using MongoDB in Docker setup)
# BASICAUTH_USERNAME=admin
# BASICAUTH_PASSWORD=admin

# ===========================================
# AI Configuration (Optional)
# ===========================================

# OpenAI API for intelligent analysis (optional but recommended)
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini API via OpenAI-compatible endpoint (Optional: to switch from OpenAI)
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# Generic/Agnostic AI Provider Configuration (Optional: overrides the above)
# AI_API_KEY=your-api-key
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# AI_MODEL=gemini-2.5-flash

# ===========================================
# Application Configuration
# ===========================================

NODE_ENV=production
PORT=3000

# Days of rotated log files to keep on disk (utils/logger.js)
# LOG_RETENTION_DAYS=60