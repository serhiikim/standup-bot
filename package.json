{
    "name": "slack-standup-bot",
    "version": "1.0.1",
    "private": true,
    "description": "AI-powered Slack standup bot with intelligent response analysis",
    "main": "app.js",
    "scripts": {
        "start": "node app.js",
        "dev": "nodemon app.js",
        "test": "for f in tests/*.test.js; do node \"$f\" || exit 1; done",
        "docker:setup": "./scripts/setup.sh",
        "docker:start": "./scripts/start.sh",
        "docker:stop": "./scripts/stop.sh",
        "docker:restart": "./scripts/restart.sh",
        "docker:logs": "./scripts/logs.sh",
        "docker:dev": "./scripts/dev.sh",
        "docker:health": "./scripts/health.sh",
        "docker:clean": "./scripts/clean.sh",
        "docker:update": "./scripts/update.sh",
        "prepare": "husky || true"
    },
    "keywords": [
        "slack",
        "bot",
        "standup",
        "ai",
        "productivity"
    ],
    "author": "Your Name",
    "license": "MIT",
    "dependencies": {
        "@slack/bolt": "^3.17.1",
        "dotenv": "^16.3.1",
        "mongodb": "^6.3.0",
        "node-cron": "^4.2.1",
        "openai": "^4.24.7",
        "rotating-file-stream": "^3.2.9",
        "sqlite": "^5.1.1",
        "sqlite3": "^6.0.1"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.2.1",
        "@commitlint/config-conventional": "^21.2.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/commit-analyzer": "^13.0.1",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.9",
        "@semantic-release/npm": "^13.1.5",
        "@semantic-release/release-notes-generator": "^14.1.1",
        "husky": "^9.1.7",
        "nodemon": "^3.0.2",
        "semantic-release": "^25.0.5"
    },
    "overrides": {
        "conventional-commits-filter": "^6.0.1"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
